# ============================================================
#  DishCraft — Docker environment template
#  cp .env.example .env  then fill in every value
# ============================================================

# ── Public URL ────────────────────────────────────────────────
# Full URL where the app will be reachable (no trailing slash).
# Used for CORS and Laravel APP_URL.
APP_URL=http://localhost

# Which port Nginx binds on the host machine
HOST_PORT=80

# ── Database ──────────────────────────────────────────────────
# MySQL root password (used by healthcheck only, not the app)
MYSQL_ROOT_PASSWORD=change_me_root_password

# Password for the 'dishcraft' app user (shared by PHP API + Laravel)
DB_PASSWORD=change_me_app_password

# ── Laravel ───────────────────────────────────────────────────
# Generate with: php artisan key:generate --show
# Or:            openssl rand -base64 32 | sed 's/^/base64:/'
APP_KEY=base64:REPLACE_WITH_REAL_KEY

# Comma-separated domains allowed to use Sanctum session auth.
# Match APP_URL host (without scheme/port for same-port 80/443).
SANCTUM_STATEFUL_DOMAINS=localhost

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated origins allowed to call the Laravel API.
# Leave blank to auto-derive from APP_URL (recommended for production).
# For local dev, the Vite proxy bypasses CORS anyway.
# CORS_ALLOWED_ORIGINS=
